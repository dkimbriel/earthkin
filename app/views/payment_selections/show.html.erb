<% content_for :title, "Complete Your Enrollment - Earthkin Nature School" %>

<style>
  /* Reset any browser default styling */
  .payment-form,
  .payment-form fieldset,
  .payment-form legend {
    border: none;
    margin: 0;
    padding: 0;
  }
  .payment-form {
    margin-top: 20px;
  }
  .form-group {
    margin-bottom: 20px;
  }
  .form-label {
    display: block;
    font-weight: bold;
    margin-bottom: 8px;
    color: #333;
  }
  .form-input {
    width: 100%;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 16px;
    box-sizing: border-box;
  }
  .form-input:focus {
    outline: none;
    border-color: #2e7d32;
    box-shadow: 0 0 0 2px rgba(46, 125, 50, 0.2);
  }
  .payment-plan-option {
    position: relative;
    display: block;
    border: 2px solid #ddd;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 15px;
    cursor: pointer;
    transition: border-color 0.2s, background-color 0.2s;
  }
  .payment-plan-option:hover {
    border-color: #4a7c59;
    background-color: #f9fdf9;
  }
  .payment-plan-option.selected {
    border-color: #2e7d32;
    background-color: #e8f5e9;
  }
  .payment-plan-option input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    margin: 0;
    padding: 0;
    pointer-events: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    border: none;
    outline: none;
  }
  /* Remove any Safari/WebKit focus indicators */
  .payment-plan-option:focus-within {
    outline: none;
  }
  label.payment-plan-option {
    -webkit-tap-highlight-color: transparent;
  }
  .plan-name {
    font-size: 18px;
    font-weight: bold;
    color: #2e7d32;
    margin-bottom: 5px;
  }
  .plan-details {
    color: #666;
    font-size: 14px;
  }
  .plan-amount {
    font-size: 24px;
    font-weight: bold;
    color: #333;
    margin-top: 10px;
  }
  .card-inputs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
  }
  .card-inputs .form-group:first-child {
    grid-column: 1 / -1;
  }
  .fee-summary {
    background-color: #fff8e1;
    border: 1px solid #ffcc02;
    border-radius: 8px;
    padding: 20px;
    margin: 25px 0;
  }
  .fee-summary h4 {
    margin: 0 0 10px 0;
    color: #f57c00;
  }
  .demo-notice {
    background-color: #e3f2fd;
    border: 1px solid #2196f3;
    border-radius: 6px;
    padding: 12px 15px;
    margin-bottom: 20px;
    font-size: 14px;
    color: #1565c0;
  }
  .venmo-box {
    background-color: #f1f8f4;
    border: 1px solid #2e7d32;
    border-radius: 8px;
    padding: 20px;
    margin: 20px 0;
    text-align: center;
  }
  .venmo-handle {
    font-size: 26px;
    font-weight: bold;
    color: #2e7d32;
    margin: 6px 0 14px 0;
  }
  .section-title {
    font-size: 18px;
    font-weight: bold;
    color: #2e7d32;
    margin: 30px 0 15px 0;
    padding-bottom: 10px;
    border-bottom: 2px solid #e8f5e9;
  }
</style>

<h2>Complete Your Enrollment</h2>

<p>Hi <%= @application.parent_first_name %>! You're almost there. Please select your preferred payment plan and complete the enrollment fee payment for <strong><%= @application.full_child_name %></strong>'s enrollment in <%= @program.name %>.</p>

<% if flash[:error] %>
  <div class="error-box">
    <%= flash[:error] %>
  </div>
<% end %>

<%= form_tag payment_selection_confirm_path(params[:token]), method: :post, class: 'payment-form' do %>

  <h3 class="section-title">1. Select Your Payment Plan</h3>

  <% @payment_plans.each do |plan| %>
    <% option = @application.payment_plan_options.find { |o| o[:id] == plan.id } || {} %>
    <% schedule = plan.generate_schedule(@program.start_date || Date.current) %>
    <% first_due = schedule.first && Date.parse(schedule.first['due_date']) %>
    <label class="payment-plan-option" id="plan-option-<%= plan.id %>">
      <%= radio_button_tag :payment_plan_id, plan.id, @application.selected_payment_plan_id == plan.id %>
      <div class="plan-name"><%= plan.name %></div>
      <div class="plan-amount">
        $<%= number_with_precision(option[:total_amount] || plan.total_amount, precision: 0) %> total
        <span style="font-size: 14px; font-weight: normal; color: #666;">
          (<%= plan.installment_count %> <%= 'payment'.pluralize(plan.installment_count) %> of $<%= number_with_precision(option[:installment_amount] || plan.installment_amount, precision: 0) %>)
        </span>
      </div>
      <% if first_due %>
        <div class="plan-details">
          <% if plan.installment_count == 1 %>
            Due <%= first_due.strftime('%B %-d, %Y') %>
          <% else %>
            First payment due <%= first_due.strftime('%B %-d, %Y') %>, then on the <%= first_due.day.ordinalize %> of each month
          <% end %>
        </div>
      <% end %>
    </label>
  <% end %>

  <div class="fee-summary">
    <h4>Enrollment Fee: $<%= number_with_precision(@application.effective_enrollment_fee, precision: 0) %></h4>
    <p style="margin: 0; font-size: 14px;">
      This non-refundable enrollment fee secures your child's spot. Your first tuition installment will be due according to your selected payment plan schedule.
    </p>
  </div>

  <h3 class="section-title">2. Send Your Enrollment Fee via Venmo</h3>

  <div class="venmo-box">
    <p style="margin-top: 0;">Please send your <strong>$<%= number_with_precision(@application.effective_enrollment_fee, precision: 0) %> enrollment fee</strong> to:</p>
    <p class="venmo-handle"><%= venmo_handle %></p>
    <p style="font-size: 14px; color: #555;">
      In the Venmo note, include <strong><%= @application.full_child_name %></strong>'s name so we can match your payment.
    </p>
    <p style="font-size: 14px; color: #555; margin-bottom: 0;">
      Prefer check or cash? Make checks payable to "Earthkin Nature School," or arrange cash in person — just let us know.
    </p>
  </div>

  <div class="demo-notice">
    Once you've sent your payment, click below to let us know your plan choice. We'll confirm your child's spot as soon as we receive your enrollment fee.
  </div>

  <div style="margin-top: 30px;">
    <%= submit_tag "I've Sent My Payment — Confirm My Plan", class: 'btn btn-large', style: 'width: 100%;' %>
  </div>

<% end %>

<script>
  // Add selected class to payment plan options
  document.querySelectorAll('.payment-plan-option input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', function() {
      document.querySelectorAll('.payment-plan-option').forEach(opt => opt.classList.remove('selected'));
      if (this.checked) {
        this.closest('.payment-plan-option').classList.add('selected');
      }
    });
    // Initialize selected state
    if (radio.checked) {
      radio.closest('.payment-plan-option').classList.add('selected');
    }
  });

</script>
