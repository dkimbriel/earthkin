<% content_for :title, "Complete Your Enrollment - Earthkin Nature School" %>

<style>
  /* Reset any browser default styling */
  .payment-form,
  .payment-form fieldset,
  .payment-form legend {
    border: none;
    margin: 0;
    padding: 0;
  }
  .payment-form {
    margin-top: 20px;
  }
  .form-group {
    margin-bottom: 20px;
  }
  .form-label {
    display: block;
    font-weight: bold;
    margin-bottom: 8px;
    color: #333;
  }
  .form-input {
    width: 100%;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 16px;
    box-sizing: border-box;
  }
  .form-input:focus {
    outline: none;
    border-color: #2e7d32;
    box-shadow: 0 0 0 2px rgba(46, 125, 50, 0.2);
  }
  .payment-plan-option {
    position: relative;
    display: block;
    border: 2px solid #ddd;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 15px;
    cursor: pointer;
    transition: border-color 0.2s, background-color 0.2s;
  }
  .payment-plan-option:hover {
    border-color: #4a7c59;
    background-color: #f9fdf9;
  }
  .payment-plan-option.selected {
    border-color: #2e7d32;
    background-color: #e8f5e9;
  }
  .payment-plan-option input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    margin: 0;
    padding: 0;
    pointer-events: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    border: none;
    outline: none;
  }
  /* Remove any Safari/WebKit focus indicators */
  .payment-plan-option:focus-within {
    outline: none;
  }
  label.payment-plan-option {
    -webkit-tap-highlight-color: transparent;
  }
  .plan-name {
    font-size: 18px;
    font-weight: bold;
    color: #2e7d32;
    margin-bottom: 5px;
  }
  .plan-details {
    color: #666;
    font-size: 14px;
  }
  .plan-amount {
    font-size: 24px;
    font-weight: bold;
    color: #333;
    margin-top: 10px;
  }
  .card-inputs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
  }
  .card-inputs .form-group:first-child {
    grid-column: 1 / -1;
  }
  .fee-summary {
    background-color: #fff8e1;
    border: 1px solid #ffcc02;
    border-radius: 8px;
    padding: 20px;
    margin: 25px 0;
  }
  .fee-summary h4 {
    margin: 0 0 10px 0;
    color: #f57c00;
  }
  .demo-notice {
    background-color: #e3f2fd;
    border: 1px solid #2196f3;
    border-radius: 6px;
    padding: 12px 15px;
    margin-bottom: 20px;
    font-size: 14px;
    color: #1565c0;
  }
  .section-title {
    font-size: 18px;
    font-weight: bold;
    color: #2e7d32;
    margin: 30px 0 15px 0;
    padding-bottom: 10px;
    border-bottom: 2px solid #e8f5e9;
  }
</style>

<h2>Complete Your Enrollment</h2>

<p>Hi <%= @application.parent_first_name %>! You're almost there. Please select your preferred payment plan and complete the enrollment fee payment for <strong><%= @application.full_child_name %></strong>'s enrollment in <%= @program.name %>.</p>

<% if flash[:error] %>
  <div class="error-box">
    <%= flash[:error] %>
  </div>
<% end %>

<%= form_tag payment_selection_confirm_path(params[:token]), method: :post, class: 'payment-form' do %>

  <h3 class="section-title">1. Select Your Payment Plan</h3>

  <% @application.payment_plan_options.each do |plan_option| %>
    <label class="payment-plan-option" id="plan-option-<%= plan_option[:id] %>">
      <%= radio_button_tag :payment_plan_id, plan_option[:id], @application.selected_payment_plan_id == plan_option[:id] %>
      <div class="plan-name"><%= plan_option[:name] %></div>
      <div class="plan-details"><%= plan_option[:description] %></div>
      <div class="plan-amount">
        $<%= number_with_precision(plan_option[:total_amount], precision: 0) %> total
        <span style="font-size: 14px; font-weight: normal; color: #666;">
          (<%= plan_option[:installment_count] %> payments of $<%= number_with_precision(plan_option[:installment_amount], precision: 0) %>)
        </span>
      </div>
    </label>
  <% end %>

  <div class="form-group" style="margin-top: 20px;">
    <%= label_tag :payment_start_date, 'Payment Schedule Start Date', class: 'form-label' %>
    <%= date_field_tag :payment_start_date, @program.start_date || Date.current, class: 'form-input', readonly: true, style: 'background-color: #f5f5f5; cursor: not-allowed;' %>
    <p style="margin-top: 8px; font-size: 14px; color: #666;">
      Your tuition payments will be due monthly starting from this date.
    </p>
  </div>

  <div class="fee-summary">
    <h4>Enrollment Fee Due Today: $<%= number_with_precision(@application.effective_enrollment_fee, precision: 0) %></h4>
    <p style="margin: 0; font-size: 14px;">
      This non-refundable enrollment fee secures your child's spot. Your first tuition installment will be due according to your selected payment plan schedule.
    </p>
  </div>

  <h3 class="section-title">2. Payment Information</h3>

  <div class="demo-notice">
    <strong>Demo Mode:</strong> This is a test payment form. No actual charges will be made. Enter any valid-looking card details to proceed.
  </div>

  <div class="card-inputs">
    <div class="form-group">
      <%= label_tag :cardholder_name, 'Cardholder Name', class: 'form-label' %>
      <%= text_field_tag :cardholder_name, params[:cardholder_name], class: 'form-input', placeholder: 'Name on card', required: true %>
    </div>

    <div class="form-group">
      <%= label_tag :card_number, 'Card Number', class: 'form-label' %>
      <%= text_field_tag :card_number, params[:card_number], class: 'form-input', placeholder: '1234 5678 9012 3456', maxlength: 19, required: true %>
    </div>

    <div class="form-group">
      <%= label_tag :card_expiry, 'Expiration Date', class: 'form-label' %>
      <%= text_field_tag :card_expiry, params[:card_expiry], class: 'form-input', placeholder: 'MM/YY', maxlength: 5, required: true %>
    </div>

    <div class="form-group">
      <%= label_tag :card_cvv, 'CVV', class: 'form-label' %>
      <%= text_field_tag :card_cvv, params[:card_cvv], class: 'form-input', placeholder: '123', maxlength: 4, required: true %>
    </div>
  </div>

  <div style="margin-top: 30px;">
    <%= submit_tag "Pay $#{number_with_precision(@application.effective_enrollment_fee, precision: 0)} Enrollment Fee", class: 'btn btn-large', style: 'width: 100%;' %>
  </div>

<% end %>

<script>
  // Add selected class to payment plan options
  document.querySelectorAll('.payment-plan-option input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', function() {
      document.querySelectorAll('.payment-plan-option').forEach(opt => opt.classList.remove('selected'));
      if (this.checked) {
        this.closest('.payment-plan-option').classList.add('selected');
      }
    });
    // Initialize selected state
    if (radio.checked) {
      radio.closest('.payment-plan-option').classList.add('selected');
    }
  });

  // Format card number with spaces
  document.getElementById('card_number').addEventListener('input', function(e) {
    let value = e.target.value.replace(/\s/g, '').replace(/\D/g, '');
    value = value.match(/.{1,4}/g)?.join(' ') || value;
    e.target.value = value;
  });

  // Format expiry date
  document.getElementById('card_expiry').addEventListener('input', function(e) {
    let value = e.target.value.replace(/\D/g, '');
    if (value.length >= 2) {
      value = value.slice(0, 2) + '/' + value.slice(2, 4);
    }
    e.target.value = value;
  });
</script>
