<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for?(:title) ? yield(:title) : 'Earthkin Nature School' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&display=swap" rel="stylesheet">
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: Helvetica, Arial, sans-serif;
        background-color: #f5f5f5;
        color: #333;
        line-height: 1.6;
      }
      .container {
        max-width: 600px;
        margin: 40px auto;
        padding: 0 20px;
      }
      .card {
        background: white;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      }
      .header {
        background-color: #2e7d32;
        padding: 30px 40px;
        text-align: center;
      }
      .header img {
        max-width: 280px;
        height: auto;
      }
      .header h1 {
        font-family: 'Comfortaa', sans-serif;
        color: white;
        font-size: 24px;
        margin-top: 10px;
      }
      .content {
        padding: 40px;
      }
      h2 {
        font-family: 'Comfortaa', sans-serif;
        color: #2e7d32;
        margin-bottom: 20px;
      }
      h3 {
        color: #2e7d32;
        margin: 25px 0 10px 0;
      }
      p {
        margin-bottom: 15px;
      }
      ul {
        margin: 15px 0;
        padding-left: 20px;
      }
      li {
        margin-bottom: 8px;
      }
      .highlight {
        background-color: #e8f5e9;
        padding: 20px;
        border-radius: 6px;
        margin: 20px 0;
        border-left: 4px solid #2e7d32;
      }
      .btn {
        display: inline-block;
        padding: 14px 28px;
        background-color: #4a7c59;
        color: white;
        text-decoration: none;
        border-radius: 6px;
        font-weight: bold;
        border: none;
        cursor: pointer;
        font-size: 16px;
      }
      .btn:hover {
        background-color: #3d6a4a;
      }
      .btn-large {
        padding: 18px 36px;
        font-size: 18px;
      }
      .footer {
        background-color: #fafafa;
        padding: 30px 40px;
        border-top: 1px solid #eee;
        text-align: center;
        color: #666;
        font-size: 14px;
      }
      .footer a {
        color: #2e7d32;
        text-decoration: none;
      }
      .success-icon {
        font-size: 64px;
        margin-bottom: 20px;
      }
      .error-box {
        background-color: #ffebee;
        border-left: 4px solid #c62828;
        padding: 15px 20px;
        margin: 20px 0;
        border-radius: 0 6px 6px 0;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="card">
        <div class="header">
          <%= image_tag '/logo.png', alt: 'Earthkin Nature School' %>
        </div>
        <div class="content">
          <%= yield %>
        </div>
        <div class="footer">
          <p><strong>Earthkin Nature School</strong><br>Richmond, VA</p>
          <p style="margin-top: 10px;">
            Questions? Contact us at <a href="mailto:earthkinnatureschool@gmail.com">earthkinnatureschool@gmail.com</a>
          </p>
        </div>
      </div>
    </div>
  </body>
</html>
